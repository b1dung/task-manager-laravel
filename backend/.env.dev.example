# ──────────────────────────────────────────────────────────────────────────
# Template .env cho DEV/STAGING site (deploy, không phải local).
# Copy thành `.env`, điền các <...>, rồi: php artisan key:generate
# KHÔNG commit file .env thật (chứa secret). File *.example này thì an toàn.
# ──────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────
APP_NAME=Taskboard
APP_ENV=staging                       # local | staging | production
APP_KEY=                              # BẮT BUỘC: `php artisan key:generate`
APP_DEBUG=false                      # true để xem lỗi trên dev; prod thật để false
APP_URL=https://dev.example.com
FRONTEND_URL=https://dev.example.com  # dùng cho CORS + link trong email
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ── Logging ───────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                       # dev: debug | prod: error

# ── Database (MySQL) ──────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=<dev_db_name>
DB_USERNAME=<dev_db_user>
DB_PASSWORD=<dev_db_password>

# ── Session / Cache / Queue / Storage ─────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_SECURE_COOKIE=true            # vì site chạy HTTPS
SESSION_DOMAIN=dev.example.com
CACHE_STORE=database
QUEUE_CONNECTION=sync                 # sync nếu KHÔNG có queue worker; database nếu có
FILESYSTEM_DISK=local

# ── Realtime: Pusher cloud ────────────────────────────────────────────────
# 3 giá trị KEY + CLUSTER phải khớp với lúc build frontend
# (VITE_PUSHER_APP_KEY / VITE_PUSHER_CLUSTER). Lệch là mất realtime.
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=<pusher_app_id>
PUSHER_APP_KEY=<pusher_key>
PUSHER_APP_SECRET=<pusher_secret>
PUSHER_APP_CLUSTER=ap1

# ── Realtime (thay thế): self-host Reverb — bỏ comment nếu dùng Reverb ─────
# BROADCAST_CONNECTION=reverb
# REVERB_APP_ID=<reverb_app_id>
# REVERB_APP_KEY=<reverb_key>         # = VITE_REVERB_APP_KEY khi build FE
# REVERB_APP_SECRET=<reverb_secret>
# REVERB_HOST=127.0.0.1               # backend publish tới Reverb (local tới server)
# REVERB_PORT=8080
# REVERB_SCHEME=http
# REVERB_SERVER_HOST=0.0.0.0          # cho lệnh `php artisan reverb:start`
# REVERB_SERVER_PORT=8080

# ── Mail ──────────────────────────────────────────────────────────────────
MAIL_MAILER=log                       # log = không gửi thật; smtp khi cần gửi
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@dev.example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ── Google OAuth (tùy chọn) ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://dev.example.com/api/v1/auth/google/callback

# ── Sentry (tùy chọn) ─────────────────────────────────────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=staging
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

# ── Backup (tùy chọn) ─────────────────────────────────────────────────────
BACKUP_DIR=/var/backups/taskboard
BACKUP_RETENTION_DAYS=30
