# ──────────────────────────────────────────────────────────────────────────
# Template .env cho PRODUCTION (task.mintoku.vn).
# Copy thành `.env` trên server, điền các <secret>, rồi: php artisan key:generate
# KHÔNG commit `.env` thật. Realtime production dùng Pusher cloud.
# ──────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────
APP_NAME=Taskboard
APP_ENV=production
APP_KEY=                                 # BẮT BUỘC: `php artisan key:generate`
APP_DEBUG=false
APP_URL=https://task.mintoku.vn
FRONTEND_URL=https://task.mintoku.vn     # CORS + link trong email (invite/reset/verify)
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ── Logging ───────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database (MySQL) ──────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=mintoku_task
DB_USERNAME=mintoku_task
DB_PASSWORD=<db_password>

# ── Session / Cache / Queue / Storage ─────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_SECURE_COOKIE=true               # site chạy HTTPS
SESSION_DOMAIN=task.mintoku.vn
CACHE_STORE=database
QUEUE_CONNECTION=sync                     # sync nếu KHÔNG có queue worker; database nếu có
FILESYSTEM_DISK=local

# ── Realtime: Pusher cloud ────────────────────────────────────────────────
# KEY + CLUSTER phải khớp lúc build FE (VITE_PUSHER_APP_KEY / VITE_PUSHER_CLUSTER).
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=2170601
PUSHER_APP_KEY=ee583f9a9e7bdf6211e1
PUSHER_APP_SECRET=<pusher_secret>
PUSHER_APP_CLUSTER=ap1                    # ⚠ KIỂM TRA cluster đúng trong Pusher dashboard

# ── Mail (SMTP) ───────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=smtp                          # port 587 = STARTTLS
MAIL_HOST=mail.task.mintoku.vn
MAIL_PORT=587
MAIL_USERNAME=admin@task.mintoku.vn
MAIL_PASSWORD=<mail_password>
MAIL_FROM_ADDRESS="admin@task.mintoku.vn"
MAIL_FROM_NAME="${APP_NAME}"

# ── Google OAuth (tùy chọn) ───────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://task.mintoku.vn/api/v1/auth/google/callback

# ── Sentry (tùy chọn) ─────────────────────────────────────────────────────
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false
